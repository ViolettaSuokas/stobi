# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# Firebase / Google services
# google-services.json трекается в git (нужен для EAS Build tarball upload)
# ⚠️ Прод-ключ нужно ротировать в Google Cloud Console + restrict by package name + SHA-1
# GoogleService-Info.plist не используется (iOS не настроен на Firebase)
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
